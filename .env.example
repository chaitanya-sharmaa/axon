# ════════════════════════════════════════════════════════════════════════════
# Axon Bridge — Environment Configuration
# Copy this file to .env and fill in your values.
#
# DESIGN PHILOSOPHY
# ─────────────────
# Axon Bridge is a token-compression-first proxy.
# All compression features are ENABLED by default — no configuration needed.
# Non-compression features (security, routing, memory) are DISABLED by default
# and must be explicitly opted-in below.
# ════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
AXON_APP_TITLE="Axon Token Bridge"
AXON_APP_VERSION="0.3.0"
# Bind address: use 0.0.0.0 to expose on your network
AXON_HOST="127.0.0.1"
AXON_PORT="8080"

# ── Logging ───────────────────────────────────────────────────────────────────
# "text" (default, human-readable) | "json" (machine-readable for Datadog etc.)
AXON_LOG_FORMAT="text"
AXON_LOG_LEVEL="INFO"


# ════════════════════════════════════════════════════════════════════════════
# ✅  TOKEN COMPRESSION FEATURES  (ON by default — no action needed)
# ════════════════════════════════════════════════════════════════════════════

# ── Token Compression Engine ──────────────────────────────────────────────────
# Benchmarks all strategies per-request and picks the winner automatically.
# Default tokenizer for token count estimation
AXON_TOKENIZER_MODEL="cl100k_base"

# Which strategies to benchmark. Leave blank to use all 8.
# Options: graph, graph_session, graph_delta, generic, generic_delta,
#          generic_session, schema_values, json
AXON_ENABLED_FORMATS=""

# Max sessions to keep in memory before LRU eviction
AXON_MAX_SESSIONS="1000"

# Enable destructive TOON/TRON stateful compression.
# WARNING: Only safe with provider-side caching (Gemini/Anthropic). Will cause
# hallucinations if enabled on standard stateless API calls.
AXON_ENABLE_STATEFUL_COMPRESSION="false"

# Enable Gemini native prompt caching (paid plan only — free tier returns 429)
AXON_ENABLE_GEMINI_PROMPT_CACHE="false"

# ── L1 KV Cache (Exact-Match) ─────────────────────────────────────────────────
# SHA-256 hash of the full request. Cache hit = 100% token savings, ~5ms latency.
# LRU cap: 1,000 entries. TTL: 1 hour.
AXON_ENABLE_EXACT_MATCH_CACHE="true"

# ── L2 Semantic Cache ─────────────────────────────────────────────────────────
# Cosine-similarity embeddings to detect paraphrased versions of the same question.
# Returns cached answer without touching the LLM.
AXON_ENABLE_SEMANTIC_CACHE="true"

# ── Tool / Function Call Compression ─────────────────────────────────────────
# Converts verbose JSON Schema tool definitions (~400 tokens) to compact Python
# function signatures (~30 tokens). ~90% reduction on tool schemas.
AXON_ENABLE_TOOL_COMPRESSION="true"

# ── Vision Downscaler ─────────────────────────────────────────────────────────
# Resizes 4K+ base64 images to 768px max before sending to LLM.
# Directly reduces vision tokens — no quality loss for most tasks.
AXON_ENABLE_VISION_OPTIMIZER="true"

# ── Agentic Optimization Pipeline ────────────────────────────────────────────
# Master switch for all 8 mathematical compression passes.
# Activates automatically when X-Axon-Session-ID header is present.
# Achieves 98% token reduction on long autonomous agent loops.
AXON_ENABLE_AGENTIC_OPTIMIZATIONS="true"

#   Pass 1: Error Truncation — compresses 50-line stack traces to 1 line (~90% savings)
AXON_ENABLE_AGENTIC_ERROR_TRUNCATION="true"
#   Pass 2: Whitespace Normalization — strips invisible Unicode, collapses spacing (5-15%)
#   Pass 3: Scratchpad Compression — deduplicates <thinking>/ReAct blocks (30-50%)
AXON_ENABLE_AGENTIC_SCRATCHPAD="true"
#   Pass 4: Parallel Deduplication — removes duplicate fields across tool results (15-40%)
#   Pass 5: Prefix Caching — injects cache_control on stable system prompts (85-90%)
#   Pass 6: Schema Differential — omits tool schemas for recently-unused tools (80%)
AXON_ENABLE_AGENTIC_SCHEMA_DIFF="true"
#   Pass 7: Observation Window — prunes old low-information tool results (40-70%)
AXON_ENABLE_AGENTIC_OBSERVATION_WINDOW="true"
#   Pass 8: Loop Circuit Breaker — detects + bypasses repeated identical tool calls (100%)
AXON_ENABLE_AGENTIC_LOOP_DETECTION="true"


# ════════════════════════════════════════════════════════════════════════════
# ❌  NON-COMPRESSION FEATURES  (OFF by default — opt-in below)
# ════════════════════════════════════════════════════════════════════════════

# ── ML Smart Router ───────────────────────────────────────────────────────────
# Uses a local sentence-transformer model (~80MB, all-MiniLM-L6-v2) to classify
# every prompt's intent and automatically route:
#   - Casual queries  → lite model (gpt-4o-mini, claude-haiku, gemini-flash)
#   - Complex queries → pro model  (gpt-4o, claude-sonnet, gemini-pro)
# Also provides smart fallback cascading on 429/503 errors.
# Supported families: OpenAI gpt, Anthropic claude, Google gemini
AXON_ENABLE_SEMANTIC_ROUTING="false"

# ── Prompt Firewall ───────────────────────────────────────────────────────────
# Scans every user message against 25+ known jailbreak and prompt-injection
# patterns before forwarding to the LLM. Returns HTTP 400 on a match.
# Enable if your proxy is exposed to untrusted users.
AXON_ENABLE_PROMPT_FIREWALL="false"

# ── PII Redactor ──────────────────────────────────────────────────────────────
# Auto-redacts personally identifiable information from all messages before
# they reach the LLM API. Supports:
#   - Email addresses
#   - Credit card numbers
#   - US Social Security Numbers (SSNs)
#   - Phone numbers (US + international formats)
# Redacted values are replaced with typed placeholders (e.g. [EMAIL]).
AXON_ENABLE_PII_REDACTION="false"

# ── Shannon Entropy Hallucination Guard ──────────────────────────────────────
# Parses logprobs from the LLM response and computes Shannon entropy:
#   E = -Σ p·log₂(p)
# If entropy > threshold, the response is flagged as potentially hallucinated.
# Requires the upstream model to return logprobs (set logprobs=true in request).
AXON_ENABLE_HALLUCINATION_GUARD="false"
AXON_ENTROPY_THRESHOLD="1.5"

# ── Fact Extraction & Session Memory ─────────────────────────────────────────
# Extracts semantic facts from conversations in the background
# (e.g. "User's name is Chaitanya", "employer: Google") and injects them
# as context into future turns via a system message.
# Requires X-Axon-Session-ID header on requests.
AXON_ENABLE_FACT_EXTRACTION="false"

# ── OpenAI Assistants API + Swarm Routing + File Uploads ─────────────────────
# Enables full drop-in support for client.beta.threads.* :
#   POST /v1/threads              — create stateful thread
#   POST /v1/threads/{id}/messages — add message (Axon stores history)
#   POST /v1/threads/{id}/runs     — execute run (streaming supported)
#   GET  /v1/threads/{id}/messages — list thread messages
# Also enables:
#   POST /v1/swarm/completions    — fan-out to multiple models + synthesis
#   POST /v1/files                — upload files for RAG
AXON_ENABLE_ASSISTANTS_ROUTES="false"

# ── RAG Context Injection ──────────────────────────────────────────────────────
# Injects relevant chunks from uploaded files into the prompt context.
# Uses local sentence-transformer embeddings + cosine similarity search.
# Requires AXON_ENABLE_ASSISTANTS_ROUTES=true to upload files.
AXON_ENABLE_RAG_CONTEXT="false"

# ── Multi-Tenant Quota Management ────────────────────────────────────────────
# Track and enforce per-tenant USD spend limits. Tenants identified via
# X-Axon-Tenant-ID header. Returns 429 when quota is exceeded.
# Manage quotas via: POST /admin/quotas/{tenant_id}
AXON_ENABLE_TENANT_QUOTAS="false"

# Admin API key required for all /admin/* endpoints (Bearer token)
# Leave unset for open dev access.
# AXON_ADMIN_API_KEY="your-admin-secret"


# ════════════════════════════════════════════════════════════════════════════
# ⚙️   INFRASTRUCTURE & OPTIONAL ROUTES
# ════════════════════════════════════════════════════════════════════════════

# ── LLM API Keys ──────────────────────────────────────────────────────────────
# Your real upstream LLM API key. Comma-separate multiple keys for load balancing.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"

# ─────────────────────────────────────────────────────────
# Serverless Storage & Replication (Optional)
# ─────────────────────────────────────────────────────────
# By default, Axon uses a local SQLite file to store sessions.
# If you deploy to a serverless platform (Vercel, AWS App Runner)
# or want global edge replication, use Turso or Redis.

# --- Turso / libSQL (Recommended Serverless Store) ---
# Set to 'turso' to use the unified libSQL driver.
# For local dev: file:./axon_sessions.db
# For production edge: libsql://your-db-name-org.turso.io
AXON_MEMORY_TYPE="turso"
AXON_TURSO_URL="file:./axon_sessions.db"
# AXON_TURSO_AUTH_TOKEN="your-turso-auth-token"

# --- Redis (Alternative) ---
# AXON_MEMORY_TYPE="redis"
# AXON_REDIS_URL="redis://localhost:6379/0"

# ── Security (API Key Enforcement) ────────────────────────────────────────────
# Require an X-API-Key header on all proxy requests
AXON_REQUIRE_API_KEY="false"
# AXON_API_KEY="your-client-api-key"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins (e.g. http://localhost:3000,https://myapp.com)
# AXON_CORS_ORIGINS=""

# ── Rate Limiting ─────────────────────────────────────────────────────────────
AXON_RATE_LIMIT_ENABLED="true"
AXON_RATE_LIMIT_PROXY="60/minute"
AXON_RATE_LIMIT_PROCESS="120/minute"

# ── Optional Route Groups (all OFF by default) ────────────────────────────────
# Enable the generic upstream HTTP proxy (/proxy/upstream)
AXON_ENABLE_PROXY_ROUTES="false"
# Enable session memory CRUD routes (/memory/*)
AXON_ENABLE_MEMORY_ROUTES="false"
# Enable domain allowlist / API key management routes (/security/*)
AXON_ENABLE_SECURITY_ROUTES="false"
# Enable multi-agent orchestration routes (/agent/dispatch, /agent/swarm, etc.)
AXON_ENABLE_AGENT_ROUTES="false"

# ── Always-on routes (do not disable unless you know what you're doing) ───────
AXON_ENABLE_CORE_ROUTES="true"
AXON_ENABLE_PROCESS_ROUTES="true"
AXON_ENABLE_OPENAI_ROUTES="true"
AXON_INCLUDE_JSON_FALLBACK="true"

# ── Route Prefixes ────────────────────────────────────────────────────────────
AXON_ROUTE_PREFIX_PROXY="/proxy"
AXON_ROUTE_PREFIX_MEMORY="/memory"
AXON_ROUTE_PREFIX_SECURITY="/security"

# ── Domain Allowlist (for /proxy/upstream) ────────────────────────────────────
# Set to "true" to allow any domain (dev only!)
AXON_ALLOW_ALL_DOMAINS="false"
AXON_ALLOWED_DOMAINS="httpbin.org,api.github.com,api.example.com,localhost,127.0.0.1"
