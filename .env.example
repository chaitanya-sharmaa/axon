# Axon Bridge — Environment Configuration
# Copy this file to .env and fill in your values.
# All variables are optional — sensible defaults are shown below.

# ── App ───────────────────────────────────────────────────────────────────────
AXON_APP_TITLE="Axon Token Bridge"
AXON_APP_VERSION="0.3.0"
AXON_HOST="127.0.0.1"
AXON_PORT="8080"

# ── Logging ───────────────────────────────────────────────────────────────────
# "text" (default, human-readable) | "json" (machine-readable for Datadog etc.)
AXON_LOG_FORMAT="text"
AXON_LOG_LEVEL="INFO"

# ── Token Optimizer ───────────────────────────────────────────────────────────
# Default tokenizer used when no model is specified
AXON_TOKENIZER_MODEL="cl100k_base"
# Comma-separated list of strategies to benchmark (leave blank for all)
# Options: graph, graph_session, graph_delta, generic, generic_delta, generic_session, schema_values, json
AXON_ENABLED_FORMATS=""
# Max sessions to keep in memory before LRU eviction
AXON_MAX_SESSIONS="1000"

# ── Memory / Persistence ──────────────────────────────────────────────────────
# "sqlite" (default) | "redis"
AXON_MEMORY_TYPE="sqlite"
AXON_MEMORY_DB_PATH="./axon_sessions.db"
# Only used when AXON_MEMORY_TYPE=redis
AXON_REDIS_URL="redis://localhost:6379/0"

# ── Security & Quotas ─────────────────────────────────────────────────────────
# Require an API key (Bearer token) for all requests
AXON_REQUIRE_API_KEY=false
# The expected API key if require_api_key is true
# AXON_API_KEY=your-secret-key-here

# Enable multi-tenant quota enforcement (checks X-Axon-Tenant-ID header)
# AXON_ENABLE_TENANT_QUOTAS=false
# Admin API key required to create/update tenant quotas via POST /v1/admin/tenants
# AXON_ADMIN_API_KEY=admin-secret-key-here
# Set to "true" to allow any upstream domain (dev only!)
AXON_ALLOW_ALL_DOMAINS="false"
# Comma-separated list of allowed upstream domains
AXON_ALLOWED_DOMAINS="httpbin.org,api.github.com,api.example.com,localhost,127.0.0.1"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
AXON_RATE_LIMIT_ENABLED="true"
# Requests per minute per IP/API-key
AXON_RATE_LIMIT_PROXY="60/minute"
AXON_RATE_LIMIT_PROCESS="120/minute"

# ── OpenAI-Compatible Proxy ───────────────────────────────────────────────────
# Your real OpenAI API key (used when forwarding /v1/chat/completions)
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"

# ── Route Prefixes & Feature Flags ───────────────────────────────────────────
AXON_ROUTE_PREFIX_PROXY="/proxy"
AXON_ROUTE_PREFIX_MEMORY="/memory"
AXON_ROUTE_PREFIX_SECURITY="/security"
AXON_ENABLE_CORE_ROUTES="true"
AXON_ENABLE_PROCESS_ROUTES="true"
AXON_ENABLE_PROXY_ROUTES="true"
AXON_ENABLE_MEMORY_ROUTES="true"
AXON_ENABLE_SECURITY_ROUTES="true"
AXON_ENABLE_AGENT_ROUTES="true"
AXON_ENABLE_OPENAI_ROUTES="true"
AXON_INCLUDE_JSON_FALLBACK="true"
